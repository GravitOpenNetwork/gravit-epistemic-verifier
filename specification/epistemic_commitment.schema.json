{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EpistemicCommitment",
  "type": "object",
  "properties": {
    "agent_id": { "type": "string" },
    "action": { "type": "string" },
    "reasoning_chain": { "type": "array", "items": { "type": "string" } },
    "context": { "type": "object" },
    "provenance_root": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" }
  },
  "required": ["agent_id", "action", "reasoning_chain"]
}
