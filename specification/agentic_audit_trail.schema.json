{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgenticAuditTrail",
  "type": "object",
  "properties": {
    "trace_id": { "type": "string" },
    "epistemic_commitment": { "$ref": "epistemic_commitment.schema.json" },
    "truth_vector": { "$ref": "truth_vector.schema.json" },
    "verification_result": {
      "type": "object",
      "properties": {
        "passed": { "type": "boolean" },
        "score": { "type": "number" },
        "checks": { "type": "object" }
      }
    },
    "settlement_proof": { "type": "object" },
    "regulator_verification": { "type": "string" }
  },
  "required": ["trace_id", "epistemic_commitment", "verification_result"]
}
